{
  "name": "ext-helper",
  "version": "1.0.0",
  "description": "Browser extension manager with enable/disable and grouping",
  "type": "module",
  "scripts": {
    "dev": "plasmo dev",
    "dev:all": "concurrently \"plasmo dev\" \"vite --config vite.config.ts\"",
    "dev:web": "vite --config vite.config.ts",
    "dev:hmr": "vite dev --config vite.config.ts",
    "build": "plasmo build",
    "build:web": "vite build --config vite.config.ts",
    "preview": "vite dev --config vite.config.ts && vite preview",
    "test": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "prepare": "husky",
    "dev:website": "vite --config vite.website.config.ts",
    "build:website": "vite build --config vite.website.config.ts"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "plasmo": "^0.90.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/chrome": "^0.0.270",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "postcss": "^8.4.49",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^5.4.0",
    "vite-plugin-static-copy": "^1.0.0",
    "vitest": "^2.1.0"
  },
  "manifest": {
    "name": "Ext Helper",
    "version": "1.0.0",
    "description": "Browser extension manager with enable/disable and grouping",
    "action": {
      "default_popup": "popup.html"
    },
    "permissions": [
      "storage",
      "management",
      "tabs",
      "alarms"
    ],
    "host_permissions": [
      "<all_urls>"
    ]
  }
}
