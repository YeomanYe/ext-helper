{
  "manifest_version": 3,
  "name": "Ext Helper - AI Extension Manager",
  "version": "2.0.0",
  "description": "AI-powered extension manager with site discovery, smart recommendations, grouping & automation.",
  "default_locale": "en",
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png",
    "128-2": "icon-256.png"
  },
  "permissions": [
    "management",
    "storage"
  ],
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png"
    }
  }
}
